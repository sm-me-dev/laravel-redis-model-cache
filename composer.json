{
  "name": "sm-me/laravel-redis-model-cache",
  "description": "Optimized Redis model and hash-set caching service for Laravel Eloquent.",
  "license": "MIT",
  "authors": [
    {
      "name": "Sm_mE",
      "email": "mohammad79eshrati@gmail.com"
    }
  ],
  "keywords": [
    "laravel",
    "redis",
    "cache",
    "eloquent",
    "model",
    "packagist"
  ],
  "require": {
    "php": "^8.4",
    "illuminate/console": "^12.0",
    "illuminate/database": "^12.0",
    "illuminate/redis": "^12.0",
    "illuminate/support": "^12.0"
  },
  "require-dev": {
    "laravel/pint": "^1.29",
    "larastan/larastan": "^3.10",
    "orchestra/testbench": "^10.0",
    "pestphp/pest": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "Sm_mE\\RedisModelCache\\": "src/"
    },
    "files": [
      "src/Support/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Sm_mE\\RedisModelCache\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Sm_mE\\RedisModelCache\\RedisModelCacheServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
